{
  "name": "@tinkerclaw/google-meet",
  "version": "2026.5.5",
  "description": "OpenClaw Google Meet participant plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/openclaw"
  },
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3",
    "typebox": "1.1.37"
  },
  "devDependencies": {
    "@tinkerclaw/plugin-sdk": "workspace:*",
    "tinkerclaw": "workspace:*"
  },
  "peerDependencies": {
    "tinkerclaw": ">=2026.5.5"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@tinkerclaw/google-meet",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.20"
    },
    "compat": {
      "pluginApi": ">=2026.5.5"
    },
    "build": {
      "openclawVersion": "2026.5.5"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
