{
  "name": "@tinkerclaw/msteams",
  "version": "2026.5.5",
  "description": "OpenClaw Microsoft Teams channel plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/openclaw"
  },
  "type": "module",
  "dependencies": {
    "@azure/identity": "4.13.1",
    "@microsoft/teams.api": "2.0.9",
    "@microsoft/teams.apps": "2.0.9",
    "express": "5.2.1",
    "jsonwebtoken": "9.0.3",
    "jwks-rsa": "4.0.1",
    "typebox": "1.1.37"
  },
  "devDependencies": {
    "@tinkerclaw/plugin-sdk": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
    "tinkerclaw": "workspace:*"
  },
  "peerDependencies": {
    "tinkerclaw": ">=2026.5.5"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "msteams",
      "label": "Microsoft Teams",
      "selectionLabel": "Microsoft Teams (Teams SDK)",
      "docsPath": "/channels/msteams",
      "docsLabel": "msteams",
      "blurb": "Teams SDK; enterprise support.",
      "aliases": [
        "teams"
      ],
      "order": 60,
      "doctorCapabilities": {
        "dmAllowFromMode": "topOnly",
        "groupModel": "hybrid",
        "groupAllowFromFallbackToAllowFrom": false,
        "warnOnEmptyGroupSenderAllowlist": true
      }
    },
    "install": {
      "npmSpec": "@tinkerclaw/msteams",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.5"
    },
    "build": {
      "openclawVersion": "2026.5.5"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
